{
  "name": "@rtx-network/toolkit-bot",
  "version": "1.0.0",
  "description": "RTX Network Toolkit Telegram Bot - A professional bot representing the RTX Network brand",
  "main": "dist/bot.js",
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "start": "node dist/bot.js",
    "dev": "nodemon --exec ts-node src/bot.ts",
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "telegram",
    "bot",
    "rtx-network",
    "toolkit",
    "typescript",
    "telegraf"
  ],
  "author": "RTX Network",
  "license": "MIT",
  "dependencies": {
    "telegraf": "^4.15.4",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.53.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}